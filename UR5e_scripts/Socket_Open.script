socket_state = socket_open("192.168.0.10", 5000)

if socket_state:
  socket_send_string(CMD_PING)
  socket_send_string("\n")
  pc_response = socket_read_line()

  if pc_response == RESP_OK_PING:
    fail_flag = 0
    textmsg("Socket open OK")
  else:
    fail_flag = 1
    textmsg("PING failed: ", pc_response)
  end

else:
  fail_flag = 1
  textmsg("Socket open FAILED")
  halt
end