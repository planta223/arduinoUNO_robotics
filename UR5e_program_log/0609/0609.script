    end
  end
  def Wait_Motor_Idle():
    $ 132 "Wait_Motor_Idle" "noBreak"
    $ 133 "스크립트: Wait_Motor_Idle.script"
    # MOTOR STATUS를 반복 조회하여 IDLE이 될 때까지 대기
    # break문 사용 불가하므로 wait_done 임시 변수 사용
    
    wait_done = 0
    
    while wait_done == 0:
      socket_send_string(CMD_MOTOR_STATUS)
      global pc_response = socket_read_line()
    
      if pc_response == RESP_MOTOR_BUSY:
        global motor_state = 1
        sleep(0.1)
    
      elif pc_response == RESP_MOTOR_IDLE:
        global motor_state = 0
        global fail_flag = 0
        global wait_done = 1
    
      else:
        global fail_flag = 1
        global wait_done = 1
      end
    end
  end
  def Check_Door_Closed():
    $ 134 "Check_Door_Closed" "noBreak"
    $ 135 "스크립트: Check_Door_Closed.script"
    socket_send_string(CMD_DOOR_STATUS)
    global pc_response = socket_read_line()
    
    if pc_response == RESP_DOOR_CLOSED:
      global door_state = 0
      global fail_flag = 0
    
    elif pc_response == RESP_DOOR_OPEN:
      global door_state = 1
      global fail_flag = 1
    
    else:
      global fail_flag = 1
    end
  end
  def Check_Door_Open():
    $ 136 "Check_Door_Open" "noBreak"
    $ 137 "스크립트: Check_Door_Open.script"
    socket_send_string(CMD_DOOR_STATUS)
    global pc_response = socket_read_line()
    
    if pc_response == RESP_DOOR_OPEN:
      global door_state = 1
      global fail_flag = 0
    
    elif pc_response == RESP_DOOR_CLOSED:
      global door_state = 0
      global fail_flag = 1
    
    else:
      global fail_flag = 1
    end
  end
  def Check_Paper_Detected():
    $ 138 "Check_Paper_Detected" "noBreak"
    $ 139 "스크립트: Check_Paper_Detected.script"
    socket_send_string(CMD_CAMERA)
    global pc_response = socket_read_line()
    
    if pc_response == RESP_PAPER_DETECTED:
      global paper_state = 1
      global fail_flag = 0
    
    elif pc_response == RESP_PAPER_NOT_DETECTED:
      global paper_state = 0
      global fail_flag = 1
    
    else:
      global fail_flag = 1
    end
  end
  def Error_Stop():
    $ 140 "Error_Stop" "noBreak"
    $ 141 "스크립트: Error_Stop.script"
    
    # 현재 task 번호에 따라 오류 메시지 출력
    if current_task == 1:
      popup("Task 1 Failed: Open Printer", title="Task Error", warning=True, error=False)
    
    elif current_task == 2:
      popup("Task 2 Failed: Pick A4 From Paper Box", title="Task Error", warning=True, error=False)
    
    elif current_task == 3:
      popup("Task 3 Failed: Place A4 To Printer Head", title="Task Error", warning=True, error=False)
    
    elif current_task == 4:
      popup("Task 4 Failed: Close Printer", title="Task Error", warning=True, error=False)
    
    elif current_task == 5:
      popup("Task 5 Failed: Open Printer Again", title="Task Error", warning=True, error=False)
    
    elif current_task == 6:
      popup("Task 6 Failed: Pick A4 From Printer Head", title="Task Error", warning=True, error=False)
    
    elif current_task == 7:
      popup("Task 7 Failed: Place A4 To Paper Box", title="Task Error", warning=True, error=False)
    
    elif current_task == 8:
      popup("Task 8 Failed: Close Printer Again", title="Task Error", warning=True, error=False)
    
    else:
      popup("Unknown Task Failed", title="Task Error", warning=True, error=False)
    end
    
    # Arduino/PC 측 정지 요청
    socket_send_string(CMD_ESTOP)
    global pc_response = socket_read_line()
    
    # 로그 출력
    textmsg("ESTOP response: ", pc_response)
    
    # UR Program 정지
    halt
  end
